# This .gitignore file is custom-configured for Unity projects.
# It ensures temporary/generated files aren't uploaded to GitHub.

/[Ll]ogs/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Cc]onfig/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Aa]rchives/

# Asset meta files must be tracked, but user settings should be ignored
/[Uu]ser[Ss]ettings/
/.vs/
/.idea/

# Autogenerated VS/MD/Consulo project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.class
*.log
*.輝

# Unity3D generated meta files
# *.meta (Keep these tracked!)

# OS autogenerated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# PlasticSCM config files
.plastic/

# Crashlytics
crashlytics-build.properties
